# ──────────────────────────────────────────────────────────────────────────
# Plantilla de PARAMETRIZACIÓN PRODUCTIVA de Factus (Iron Body Neiva).
# SIN secretos reales: rellenar en el .env del servidor productivo.
# Bloque para fusionar con el .env de producción; NO sustituye al .env completo.
#
# Reglas:
#   · No activar FACTUS_ENABLED=true hasta que `billing:factus-doctor` diga LISTO
#     y exista ventana de prueba aprobada.
#   · En el servidor productivo, FACTUS_ENV DEBE ser "production" (un guard impide
#     emitir si APP_ENV=production y FACTUS_ENV=sandbox).
# ──────────────────────────────────────────────────────────────────────────

# Interruptor maestro (se activa al final del go-live).
FACTUS_ENABLED=false

# Ambiente productivo.
FACTUS_ENV=production
FACTUS_BASE_URL=https://api.factus.com.co

# Credenciales OAuth2 PRODUCCIÓN  ← las entrega Factus/Halltec.
FACTUS_CLIENT_ID=
FACTUS_CLIENT_SECRET=
FACTUS_USERNAME=
FACTUS_PASSWORD=

# Numeración (resolución DIAN)  ← las entrega Factus (panel).
FACTUS_NUMBERING_RANGE_ID=
FACTUS_CREDIT_NUMBERING_RANGE_ID=

# 🔒 Bloqueo tributario  ← lo confirma el CONTADOR (tras asignar tax_rate_id a planes).
FACTUS_TAX_DECISION_CONFIRMED=false

# Emisor (RUT)  ← datos del CLIENTE (ya conocidos).
FACTUS_COMPANY_NIT=1075265137
FACTUS_COMPANY_DV=1
FACTUS_COMPANY_NAME=PAJOY MEDINA FREDY ALBERTO
FACTUS_COMPANY_EMAIL=fredypajoy52@gmail.com
FACTUS_COMPANY_PHONE=3125191764
FACTUS_COMPANY_ADDRESS=CR 33 B 23 35
FACTUS_COMPANY_CITY_CODE=41001
FACTUS_COMPANY_DEPARTMENT_CODE=41

# Defaults de documento (catálogo Factus).
FACTUS_DEFAULT_MUNICIPALITY_CODE=41001
FACTUS_DEFAULT_LEGAL_ORGANIZATION_CODE=2
FACTUS_DEFAULT_TRIBUTE_CODE=ZZ
FACTUS_DEFAULT_PAYMENT_FORM=1
FACTUS_DEFAULT_PAYMENT_METHOD_CODE=10
FACTUS_DEFAULT_UNIT_MEASURE_CODE=94
FACTUS_DEFAULT_STANDARD_CODE=999
FACTUS_DEFAULT_TAX_CODE=01
FACTUS_DEFAULT_TAX_RATE=19.00
FACTUS_DOCUMENT_CODE=01
FACTUS_OPERATION_TYPE=10

# Consumidor final.
FACTUS_CONSUMER_FINAL_DOCUMENT_TYPE=13
FACTUS_CONSUMER_FINAL_DOCUMENT_NUMBER=222222222222
FACTUS_CONSUMER_FINAL_NAME=Consumidor final

# Emisión automática (apagada: factura a solicitud del cliente).
FACTUS_MEMBERSHIPS_AUTO_EMIT=false
FACTUS_PRODUCT_SALES_AUTO_EMIT=false
