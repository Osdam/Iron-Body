APP_NAME=Laravel
APP_ENV=local
APP_KEY=

# ── BLINDAJE ADMIN / CRM ────────────────────────────────────────────────────
# El panel se autentica con LOGIN REAL (email + contraseña) → token de sesión.
# Crea admins con:  php artisan admin:create --email= --name= --role=super_admin
#
# ADMIN_API_TOKEN es un secreto compartido OPCIONAL que sigue valiendo como
# FALLBACK para automatizaciones (n8n): se envía como `Authorization: Bearer
# <token>` y cruza el blindaje sin sesión. Si queda vacío, simplemente no hay
# fallback y todo /api/admin/* exige una sesión admin válida.
# Genera uno fuerte:  openssl rand -hex 32
ADMIN_API_TOKEN=
# Caducidad de la sesión admin (minutos) y de "recuérdame" (días).
ADMIN_SESSION_TTL_MINUTES=720
ADMIN_SESSION_REMEMBER_DAYS=30
APP_DEBUG=true
APP_URL=http://localhost
# URL pública del backend (para construir enlaces absolutos accesibles desde el
# móvil: proxy de GIF, PDFs, etc.). En producción = dominio HTTPS real.
#   Producción: APP_PUBLIC_URL=https://api.ironbodyneiva.cloud
APP_PUBLIC_URL=

# ── PRODUCCIÓN ──────────────────────────────────────────────────────────────
# En el servidor (api.ironbodyneiva.cloud) este .env DEBE quedar así:
#   APP_ENV=production
#   APP_DEBUG=false        ← NUNCA true en producción (filtra trazas/SQL)
#   APP_URL=https://api.ironbodyneiva.cloud
#   APP_PUBLIC_URL=https://api.ironbodyneiva.cloud
# Genera la clave una sola vez con:  php artisan key:generate

MEMBER_REGISTRATION_TOKEN=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL es la ÚNICA base real (dev y producción). NO usar SQLite.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ironbody
DB_USERNAME=iron
DB_PASSWORD=Ironbody456

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Pagos ───────────────────────────────────────────────────────────────────
# La integración ePayco y el Nequi-directo se RETIRARON como pasarela activa en
# la migración a Wompi. La configuración de Wompi es el bloque WOMPI_* (abajo).
# Los registros históricos (payments con method=epayco/nequi) siguen legibles.

# ── Wompi (Bancolombia) — PASARELA ACTIVA. Llaves privadas SOLO backend ─────────
# Solo placeholders. NUNCA commitear llaves reales. La llave PÚBLICA puede vivir
# en la app (no es secreta); la PRIVATE/INTEGRITY/EVENTS jamás salen del backend.
# Sandbox usa llaves *_test_*; producción usa *_prod_*. WompiConfigValidator
# rechaza arrancar si el ambiente no coincide con el prefijo de las llaves.
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=
WOMPI_API_URL=https://sandbox.wompi.co/v1
WOMPI_PRODUCTION_API_URL=https://production.wompi.co/v1
# Si quedan vacías se derivan de APP_URL (rutas internas).
WOMPI_WEBHOOK_URL=
WOMPI_REDIRECT_URL=
# ── Web Checkout / Link de pago Wompi (link reutilizable, p. ej. WhatsApp) ──
# Aditivo: NO cambia el flujo in-app. La membresía sigue activándose SOLO por
# el webhook Wompi aprobado. Base del checkout hosteado (igual sandbox/prod; la
# llave pública define el ambiente). Requiere WOMPI_PUBLIC_KEY + INTEGRITY_SECRET.
WOMPI_CHECKOUT_URL=https://checkout.wompi.co/p/
# URL pública de retorno tras pagar (si vacío, usa WOMPI_REDIRECT_URL).
WOMPI_CHECKOUT_REDIRECT_URL=
# Vigencia local del link (minutos) → sella expires_at de la transacción.
WOMPI_CHECKOUT_EXPIRATION_MINUTES=1440
WOMPI_TIMEOUT_SECONDS=30
WOMPI_CONNECT_TIMEOUT_SECONDS=10
WOMPI_RECONCILIATION_ENABLED=true
WOMPI_RECONCILIATION_MINUTES=5
# Minutos máx que un pago puede quedar pending/requires_action antes de expirar.
WOMPI_MAX_PENDING_MINUTES=60
# Reintentos de reconciliación por pago antes de marcar expired.
WOMPI_RECONCILIATION_MAX_RETRIES=24

# ── Contratos / Consentimiento / Firma electrónica ──────────────────────────
# Disco privado donde viven las plantillas PDF y los contratos firmados.
CONTRACTS_DISK=local
# URLs legales que ve el usuario ANTES de firmar. Si se dejan vacías, el backend
# sirve sus propias páginas en /api/legal/*. En producción apunta al dominio real.
#   PRIVACY_POLICY_URL=https://api.ironbodyneiva.cloud/api/legal/privacy
#   TERMS_URL=https://api.ironbodyneiva.cloud/api/legal/terms
PRIVACY_POLICY_URL=
TERMS_URL=
SUPPORT_CONTACT=Ironbodyneiva@gmail.com
# Plantilla de inscripción por defecto (workout_registration | basic_registration).
CONTRACTS_DEFAULT_REGISTRATION=workout_registration

# ── WorkoutX (referencias visuales de ejercicios con GIF) ───────────────────
WORKOUTX_API_KEY=
WORKOUTX_BASE_URL=https://api.workoutxapp.com

# ── Proveedor de referencias visuales (exercisedb | fitgif | workoutx | freeexercisedb | local) ──
# Recomendado: exercisedb (FitGif fue descontinuado).
EXERCISE_PROVIDER=exercisedb
SHOW_WORKOUTX_GIFS=false
SHOW_FITGIF_GIFS=true
SHOW_FREE_EXERCISE_DB=false
# ExerciseDB (AscendAPI v1): proveedor principal de GIF animado (mini-video).
# Endpoint OSS abierto (SIN key) → no necesitas registrarte para empezar.
# La key/host solo si decides usar el host de RapidAPI en vez del OSS.
EXERCISEDB_BASE_URL=https://oss.exercisedb.dev
EXERCISEDB_RAPIDAPI_HOST=
EXERCISEDB_RAPIDAPI_KEY=
# FitGif (DESCONTINUADO — el servicio cerró). Se deja por compatibilidad.
FITGIF_BASE_URL=https://fitgif.vercel.app
FITGIF_API_KEY=
FITGIF_VIDEO_SPEED=1.5
FITGIF_VIDEO_FPS=60
FITGIF_VIDEO_WIDTH=540
FITGIF_VIDEO_CRF=26
# Free Exercise DB: fallback open data (sin key, sin watermark).
FREEEXERCISEDB_BASE_URL=https://cdn.jsdelivr.net/gh/yuhonas/free-exercise-db@main

# ── IRON IA (OpenAI) — SOLO backend, la key NUNCA va en Flutter ─────────────
# Flutter → Laravel → OpenAI. No subir la key al repositorio.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com
# IRON IA multimodal — modelos configurables (no se queman en código).
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4.1-mini
# IRON IA — conversación de voz en vivo (OpenAI Realtime GA).
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy
IRON_AI_REALTIME_ENABLED=true
IRON_AI_ENABLED=true
# Sub-funciones de IRON IA (apágalas por separado sin tumbar el chat general).
IRON_AI_NUTRITION_ENABLED=true
IRON_AI_COACH_ENABLED=true
IRON_AI_MAX_CONTEXT_MESSAGES=12
# IRON_AI_TEMPERATURE=0.4
# IRON_AI_MAX_TOKENS=600
# IRON_AI_TIMEOUT=30
# IRON_AI_MEDIA_TIMEOUT=60
# IRON_AI_MAX_AUDIO_SECONDS=60
# IRON_AI_MAX_IMAGE_SIZE_MB=5
# IRON_AI_MAX_AUDIO_SIZE_MB=25
# Timeout de las llamadas a OpenAI (segundos).
OPENAI_TIMEOUT=30

# ── Automatización Laravel → n8n ────────────────────────────────────────────
# Laravel emite eventos saneados a n8n (outbox pattern). n8n NUNCA accede a la
# base de datos: solo recibe el webhook firmado (HMAC) con un payload mínimo.
# Si N8N_ENABLED=false los eventos quedan en 'skipped' (no se envían) y la app
# sigue funcionando igual.
N8N_ENABLED=false
# URL del webhook de n8n (defínela cuando exista; NO usar ngrok en producción).
N8N_WEBHOOK_URL=
# Secreto compartido: bearer + clave HMAC del payload saliente. Genera uno largo.
N8N_WEBHOOK_SECRET=
# Timeout del POST a n8n (segundos).
N8N_TIMEOUT=10

# ── Endpoints internos de automatización (los dispara n8n, firmados HMAC) ────
# n8n llama de vuelta a /api/internal/automation/* con este secreto (Bearer) y,
# opcionalmente, una firma HMAC del cuerpo. Nunca son públicos sin firma.
AUTOMATION_INTERNAL_SECRET=
# Cabeceras de firma/anti-replay (defaults; ajusta solo si tu n8n usa otras).
AUTOMATION_HMAC_HEADER=X-IronBody-Signature
AUTOMATION_TIMESTAMP_HEADER=X-IronBody-Timestamp
AUTOMATION_MAX_SKEW_SECONDS=300

# ── Agente Comercial IA (Fase 0/1) — módulo Mercadeo (marketing_*) ──────────
# INERTE por defecto. false = los disparadores externos del agente no envían
# WhatsApp/IG/FB ni inician llamadas (modo seguro). Generar un link de pago
# NUNCA activa membresía (eso es exclusivo del webhook Wompi aprobado).
MARKETING_AGENT_ENABLED=false
# Seguimientos automáticos (marketing:dispatch-followups).
MARKETING_FOLLOWUPS_DISPATCH=false
MARKETING_FOLLOWUPS_SCHEDULER=false
MARKETING_FOLLOWUPS_MINUTES=10
MARKETING_FOLLOWUPS_BATCH=100

# ── Cerebro comercial IA (Fase 2/3) ─────────────────────────────────────────
# Driver del cerebro: fake (reglas locales, default) | openai (requiere config
# segura + OPENAI_API_KEY ya existente). Con la config por defecto NO se llama a
# OpenAI. Laravel SIEMPRE valida y ejecuta (el modelo solo recomienda).
MARKETING_SALES_AI_DRIVER=fake
# Aunque el driver sea openai, esto debe ser true para usarlo (doble interruptor).
MARKETING_OPENAI_ENABLED=false
# Modelo OpenAI (si vacío, reusa OPENAI_MODEL de IRON IA). La API key se toma de
# OPENAI_API_KEY (NO se define una llave aparte aquí).
MARKETING_OPENAI_MODEL=
MARKETING_OPENAI_TIMEOUT=20
MARKETING_OPENAI_MAX_RETRIES=1
MARKETING_OPENAI_TEMPERATURE=0.2
MARKETING_OPENAI_MAX_OUTPUT_TOKENS=1200
# No loguear prompts por defecto (privacidad / sin secretos).
MARKETING_OPENAI_LOG_PROMPTS=false
# true = ante error/JSON inválido devuelve decisión segura; false = cae a fake.
MARKETING_OPENAI_FAIL_CLOSED=true

# ── Iron Body Proactive Coach (Fase 2) — eventos de comportamiento ──────────
# INERTE por defecto. true = el scheduler agenda los detectores nuevos. Rollback
# = volver a false + php artisan config:cache. No afecta el flujo base.
PROACTIVE_COACH_ENABLED=false
# module.discovery requiere tracking app_module_usages poblado por Flutter (Fase 3).
PROACTIVE_COACH_DISCOVERY_ENABLED=false
# Presupuesto anti-spam por miembro/día (además del gate de AppNotificationService).
# PROACTIVE_COACH_MAX_STRONG=1
# PROACTIVE_COACH_MAX_TOTAL=2
# Ventana de silencio (hora local de negocio). No emite en este rango.
# PROACTIVE_COACH_QUIET_START=21
# PROACTIVE_COACH_QUIET_END=8

# ── Firebase Cloud Messaging (push nativo, HTTP v1) — SOLO backend ──────────
# Las credenciales viven en el servidor; la app nunca las ve. Si FCM_ENABLED=
# false o falta el JSON, el push es un no-op (la notificación in-app sí se crea).
FCM_ENABLED=false
FCM_PROJECT_ID=
# Ruta al service account JSON (NO commitear el archivo real).
FCM_CREDENTIALS=storage/app/firebase/service-account.json
# Solo empujar push para notificaciones marcadas como importantes (evita spam).
FCM_ONLY_POPUP=true

# ── Colas y Scheduler (PRODUCCIÓN requiere infraestructura siempre activa) ───
# QUEUE_CONNECTION ya está definido arriba (=database). El envío a n8n y el push
# se procesan en cola: SIN un worker persistente los jobs no se ejecutan.
#
# Worker persistente (usar supervisor para auto-reinicio):
#   php artisan queue:work --tries=3 --max-time=3600
#
# Scheduler (detectores del coach, recordatorios): requiere cron del SO:
#   * * * * * cd /ruta/al/backend && php artisan schedule:run >> /dev/null 2>&1

# ── Meta (Facebook / Instagram / WhatsApp / Ads) — SOLO backend ─────────────
# Integración comercial: métricas de pauta, mensajería y leads. Los tokens
# viven SOLO aquí; nunca en Angular ni Flutter. Mientras META_ENABLED=false,
# los servicios NO hacen llamadas a Graph API (scaffolding seguro).
# Los webhooks de Meta requieren un dominio HTTPS público y verificado
# (NO ngrok en producción): GET/POST /api/webhooks/meta.
META_ENABLED=false
META_APP_ID=
META_APP_SECRET=
# Token que Meta echa al verificar el webhook (GET hub.verify_token). Inventa uno largo.
META_VERIFY_TOKEN=
# Secreto para validar la firma X-Hub-Signature-256 de los POST (= App Secret normalmente).
META_WEBHOOK_SECRET=
META_GRAPH_VERSION=v21.0
# Token de larga duración / System User token (se renueva server-side). DEBE ser
# un token VÁLIDO para WhatsApp Cloud API. Vive SOLO en el backend; NUNCA en el
# frontend (Angular/Flutter). Sin él, los envíos quedan en dry_run.
META_ACCESS_TOKEN=
META_PAGE_ID=
META_INSTAGRAM_ACCOUNT_ID=
META_AD_ACCOUNT_ID=
META_BUSINESS_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
# ID del número en WhatsApp Cloud API (phone_number_id), NO el teléfono visible.
# Es obligatorio para el envío real; el `meta:doctor` lo reporta SET/MISSING.
META_WHATSAPP_PHONE_NUMBER_ID=
# Número visible de WhatsApp (solo informativo para el CRM, p. ej. +57...).
WHATSAPP_DISPLAY_PHONE=
META_API_TIMEOUT=20
# Los IDs reales de los activos (business/page/ig/ad account/waba/phone/app)
# van SOLO en el .env del servidor; aquí se dejan vacíos a propósito.

# ── Verificación en dos pasos (OTP por SMS) — SOLO backend ──────────────────
# Toda la lógica de OTP vive en el servidor. El canal es pluggable:
#   dev       → NO envía SMS; registra el código en el log (solo APP_ENV=local).
#   twilio    → SMS real vía Twilio Messages API (ver bloque Twilio abajo).
#   labsmobile→ SMS real vía LabsMobile.
# En PRODUCCIÓN: OTP_DRIVER debe ser 'twilio' (o 'labsmobile') y OTP_EXPOSE_CODE=false.
OTP_DRIVER=dev
OTP_CODE_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_MAX_RESENDS=3
OTP_RESEND_COOLDOWN=60
# Devolver el código en la respuesta de la API: SOLO útil con driver dev. NUNCA
# en producción (déjalo en false aunque el driver sea real).
OTP_EXPOSE_CODE=false
# Miembros sin teléfono: en demo se permite entrar sin OTP. En producción ponlo
# en false para forzar el 2FA siempre.
OTP_SKIP_WHEN_NO_PHONE=true
# Vínculo dispositivo↔titular (anti cuentas compartidas). Mantener en true.
OTP_DEVICE_BINDING=true
# Marca que aparece en el cuerpo del SMS.
OTP_BRAND="Iron Body"
# Concurrencia: bloquea la cuenta si ya está activa en otro dispositivo principal.
# session_grace = segundos sin actividad antes de permitir el relevo de sesión.
OTP_BLOCK_CONCURRENT=true
OTP_SESSION_GRACE=180
# Detección de velocidad sospechosa: más de N dispositivos distintos en `window` seg.
OTP_SUSPICIOUS_WINDOW=600
OTP_SUSPICIOUS_MAX_DEVICES=3

# ── Portal profesional de entrenadores (feature flags) — SOLO backend ────────
# El portal profesional es ADITIVO y nace APAGADO: con todo en false la app se
# comporta exactamente como hoy (el miembro normal no ve nada). El backend es la
# autoridad de las banderas; Flutter solo oculta UI. El acceso profesional REUSA
# el motor OTP de arriba (mismo OTP_DRIVER/Twilio). No requiere secretos nuevos.
TRAINER_PORTAL_ENABLED=false
TRAINER_AUTH_ENABLED=false
TRAINER_PROFESSIONAL_ASSESSMENTS_ENABLED=false
TRAINER_CLASSES_ENABLED=false
TRAINER_WORKSPACE_SWITCHING_ENABLED=false
# Piloto: ids de identidad (tabla `identities`) habilitadas aunque las banderas
# globales estén en false. Lista separada por comas. Vacío = sin piloto.
TRAINER_PILOT_IDENTITIES=

# ── Verificación facial del titular (tras el OTP) — SOLO backend ─────────────
# El emparejamiento ocurre EN EL DISPOSITIVO (TFLite); el backend solo entrega la
# referencia a una sesión recién verificada por OTP y audita el veredicto.
#   enabled  → exige cara cuando el miembro tiene foto de referencia.
#   required → fuerza la cara aunque el miembro no tenga referencia previa.
OTP_FACE_ENABLED=true
OTP_FACE_REQUIRED=true
OTP_FACE_TICKET_TTL=600
OTP_FACE_MAX_ATTEMPTS=3
# Guardar el selfie de cada verificación (auditoría, disco privado).
OTP_FACE_STORE_SELFIE=false
# Re-enrolamiento biométrico cross-platform (referencias legacy que fallan por
# incompatibilidad de plantilla, NO por ser otra persona). No baja el umbral.
OTP_FACE_REENROLL_ENABLED=true
OTP_FACE_REENROLL_SCORE_MAX=1.6
OTP_FACE_REENROLL_TOKEN_TTL=300

# ── Twilio (OTP en producción) — SOLO backend, NUNCA commitear ──────────────
# Dos modos (con OTP_DRIVER=twilio):
#   A) Verify API (RECOMENDADO): define TWILIO_VERIFY_SERVICE_SID. Twilio genera,
#      envía y valida el código (no necesita un número `from`).
#   B) Messages API: define TWILIO_FROM (número E.164 con SMS a Colombia) y NO
#      definas Verify SID.
# Acepta tanto TWILIO_SID/TWILIO_TOKEN como los nombres de la consola Twilio
# (TWILIO_ACCOUNT_SID/TWILIO_AUTH_TOKEN).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
# Solo si usas Messages API (modo B):
TWILIO_FROM=
# Bases (override solo si lo necesitas):
TWILIO_BASE=https://api.twilio.com
TWILIO_VERIFY_BASE=https://verify.twilio.com
# Prefijo de país para normalizar a E.164 (Colombia = 57).
OTP_DEFAULT_COUNTRY_CODE=57

# ── LabsMobile (proveedor SMS alternativo, con OTP_DRIVER=labsmobile) ────────
# Solo rellenar si NO usas Twilio. SOLO backend, nunca commitear credenciales.
LABSMOBILE_USERNAME=
LABSMOBILE_TOKEN=
LABSMOBILE_SENDER=IronBody

# ── Login adaptativo por riesgo (dispositivo principal sin 2FA tedioso) ─────
# Ver docs/SEGURIDAD_LOGIN_ADAPTATIVO.md. APAGADO por defecto: con false el login
# pide OTP + cara SIEMPRE (comportamiento clásico). Con true, la fuerza del login
# se adapta a la confianza del equipo y al riesgo:
#   equipo NO vinculado            → OTP + cara.
#   vinculado + riesgo alto        → OTP + cara (step-up).
#   vinculado + riesgo medio       → solo OTP.
#   vinculado + riesgo bajo (cero) → desbloqueo local (Face ID/huella), sin SMS.
SECURITY_ADAPTIVE_LOGIN=false
# Bajo este puntaje (y equipo confiable) se permite desbloqueo local. 1 ⇒ solo
# riesgo CERO entra con biometría local; cualquier señal exige al menos OTP.
SECURITY_LOCAL_THRESHOLD=1
# Vigencia (segundos) del ticket de desbloqueo local.
SECURITY_LOCAL_TICKET_TTL=180

# ── Suspensión automática por riesgo (Fase 10) ─────────────────────────────
# APAGADO por defecto: el sistema solo AVISA al cruzar el umbral; no bloquea.
# Los bloqueos MANUALES del CRM aplican siempre, sin importar este flag.
SECURITY_AUTOSUSPEND=false
SECURITY_SUSPEND_DAYS=3
SECURITY_RISK_WINDOW=3600
SECURITY_WARN_THRESHOLD=40
SECURITY_SUSPEND_THRESHOLD=80

# ── Story Live / transmisiones en vivo (LiveKit) — SOLO backend ─────────────
# Ver docs/STORY_LIVE.md. APAGADO por defecto: sin credenciales, la función se
# presenta como "no disponible" en la app (nunca crashea). El backend acuña los
# tokens de sala server-side; la api_secret NUNCA llega a la app ni al repo.
LIVE_ENABLED=false
LIVE_PROVIDER=livekit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL=3600

# ── Nutrición premium (búsqueda de alimentos / barcode / OCR) ────────────────
# Flutter NUNCA llama a proveedores externos; todo pasa por el backend.
NUTRITION_EXTERNAL_SEARCH_ENABLED=true
NUTRITION_OPENFOODFACTS_ENABLED=true
NUTRITION_OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org
NUTRITION_USDA_ENABLED=false
NUTRITION_USDA_BASE_URL=https://api.nal.usda.gov/fdc/v1
NUTRITION_USDA_API_KEY=
NUTRITION_NUTRITIONIX_ENABLED=false
NUTRITION_NUTRITIONIX_APP_ID=
NUTRITION_NUTRITIONIX_APP_KEY=
NUTRITION_OCR_ENABLED=false
NUTRITION_OCR_PROVIDER=tesseract
NUTRITION_OCR_TESSERACT_BIN=/usr/bin/tesseract
NUTRITION_OCR_LANG=spa+eng
NUTRITION_OCR_TIMEOUT_SECONDS=20
NUTRITION_OCR_MAX_IMAGE_MB=8
NUTRITION_OCR_STORE_ORIGINAL=false
NUTRITION_OCR_REQUIRE_USER_CONFIRMATION=true
# Base comunitaria: alimentos creados por usuarios que retroalimentan la base.
NUTRITION_COMMUNITY_REPORTS_HIDE_THRESHOLD=3
NUTRITION_COMMUNITY_IDEMPOTENCY_WINDOW=15
# Metas por defecto para constancia/adherencia (aún no hay meta por usuario).
NUTRITION_GOAL_CALORIES=2200
NUTRITION_GOAL_PROTEIN=150
NUTRITION_GOAL_CARBS=250
NUTRITION_GOAL_FAT=70
NUTRITION_GOAL_TOLERANCE=0.10
# Capa IA (OpenAI) de asistencia — la API key vive en OPENAI_API_KEY (no aquí).
NUTRITION_AI_ENABLED=false
NUTRITION_AI_PROVIDER=openai
NUTRITION_AI_MODEL_LABEL_IMAGE=
NUTRITION_AI_MODEL_TEXT=
NUTRITION_AI_MODEL_ESTIMATE=
NUTRITION_AI_MODEL_INSIGHTS=
NUTRITION_AI_MODEL_ADMIN=
NUTRITION_AI_TIMEOUT_SECONDS=30
NUTRITION_AI_MAX_IMAGE_MB=6
NUTRITION_AI_RATE_LIMIT_PER_USER=20
NUTRITION_AI_DAILY_COST_GUARD=1000
NUTRITION_AI_CACHE_ENABLED=true
NUTRITION_AI_MIN_CONFIDENCE_AUTOFILL=0.70
NUTRITION_AI_MIN_CONFIDENCE_ESTIMATE=0.60
NUTRITION_AI_PROMPT_VERSION=v1
NUTRITION_CACHE_TTL_DAYS=90
NUTRITION_SEARCH_TIMEOUT_SECONDS=8
NUTRITION_BARCODE_TIMEOUT_SECONDS=8
# Open Food Facts: User-Agent identificable (lo exige OFF), país/idioma e
# importador masivo opcional desde dump local (deshabilitado por defecto).
NUTRITION_OFF_USER_AGENT="IronBodyNeiva/1.0 (soporte@ironbodyneiva.cloud)"
NUTRITION_OFF_COUNTRY=colombia
NUTRITION_OFF_LANGUAGE=es
# Cobertura Colombia (cadenas, marcas locales y prefijos de barcode priorizados).
NUTRITION_OFF_COLOMBIA_ENABLED=true
NUTRITION_OFF_COLOMBIA_RETAILERS="D1,Tiendas D1,Éxito,Exito,Carulla,Surtimax,Super Inter,Olímpica,Olimpica,Ara,Jumbo,Metro,Alkosto,PriceSmart,Colsubsidio,Euro,La 14,Popular"
NUTRITION_OFF_COLOMBIA_BRAND_SEEDS="D1,Éxito,Exito,Carulla,Ara,Olímpica,Olimpica,Zenú,Zenu,Colanta,Alpina,Alquería,Alqueria,Noel,Ramo,Jet,Postobón,Postobon,Hatsu,Fruco,La Muñeca,Diana,Roa,Florhuila,Doña Gallina,Margarita,Nestlé,Nestle,Kellogg,Quaker,Bimbo,Colombina,Frutiño,Frutino,Juan Valdez,Sello Rojo,Águila Roja,Aguila Roja"
NUTRITION_OFF_COLOMBIA_BARCODE_PREFIXES="770"
NUTRITION_OFF_IMPORT_COLOMBIA_PRIORITY=true
NUTRITION_OFF_IMPORT_ENABLED=false
NUTRITION_OFF_IMPORT_PATH=
NUTRITION_OFF_IMPORT_BATCH_SIZE=500
NUTRITION_OFF_IMPORT_LIMIT=

# ──────────────────────────────────────────────────────────────────────────
# Facturación electrónica DIAN — Factus / Halltec (API V2)
# Interruptor maestro apagado por defecto: las facturas quedan 'pending' y
# NUNCA se llama a Factus hasta que se active con credenciales reales.
# Pasar a producción = cambiar SOLO estas variables (sin tocar código).
# NO commitear secretos: dejar vacíos los campos sensibles.
# ──────────────────────────────────────────────────────────────────────────
FACTUS_ENABLED=false
FACTUS_ENV=sandbox
FACTUS_BASE_URL=https://api-sandbox.factus.com.co

# Envío PROPIO (SMTP) del comprobante al correo del cliente — FALLBACK al envío
# nativo de Factus (que en producción devolvió send_email=false / email=null).
# Best-effort: su fallo NUNCA revierte la factura ya validada. Usa la config
# MAIL_* estándar de Laravel. Opt-in:
BILLING_SEND_CUSTOMER_EMAIL=false
BILLING_CUSTOMER_EMAIL_ATTACH_PDF=true
BILLING_CUSTOMER_EMAIL_ATTACH_XML=true
# Branding del correo del comprobante (solo presentación). Fondo exterior gris
# suave + tarjeta blanca centrada con header NEGRO. Usa por defecto el asset
# público brand/iron-body-email-logo.png (logo optimizado con fondo #000000
# uniforme que se funde con el header negro; se resuelve a URL absoluta contra
# APP_URL). Define BILLING_EMAIL_LOGO_URL solo si quieres forzar otra URL absoluta
# HTTPS; si no existe el asset ni esta var, el header cae a un fallback "IRON BODY".
# BILLING_EMAIL_LOGO_URL=https://api.ironbodyneiva.cloud/brand/iron-body-email-logo.png
BILLING_EMAIL_SUPPORT=facturacion@ironbodyneiva.cloud

# Credenciales OAuth2 (password grant) — SECRETAS, solo backend.
FACTUS_USERNAME=
FACTUS_PASSWORD=
FACTUS_CLIENT_ID=
FACTUS_CLIENT_SECRET=

# Cliente HTTP / reintentos / token.
FACTUS_TIMEOUT=30
FACTUS_CONNECT_TIMEOUT=10
FACTUS_RETRY_TIMES=5
FACTUS_RETRY_BACKOFF_SECONDS=60
FACTUS_TOKEN_CACHE_SECONDS=3000
FACTUS_QUEUE=billing

# Valores por defecto del documento (códigos del catálogo Factus).
FACTUS_DEFAULT_PAYMENT_METHOD_CODE=
FACTUS_DEFAULT_TRIBUTE_ID=

# Consumidor final (cuando faltan datos fiscales, sin bloquear el cobro).
FACTUS_CONSUMER_FINAL_DOCUMENT_TYPE=
FACTUS_CONSUMER_FINAL_DOCUMENT_NUMBER=
FACTUS_CONSUMER_FINAL_NAME=Consumidor final

# Numeración / resolución DIAN (la administra Factus por su rango).
FACTUS_NUMBERING_RANGE_ID=
FACTUS_NUMBERING_PREFIX=

# Datos fiscales del emisor (la empresa que factura).
FACTUS_COMPANY_NIT=
FACTUS_COMPANY_DV=
FACTUS_COMPANY_NAME=
FACTUS_COMPANY_EMAIL=
FACTUS_COMPANY_PHONE=
FACTUS_COMPANY_ADDRESS=
FACTUS_COMPANY_CITY_CODE=
FACTUS_COMPANY_DEPARTMENT_CODE=

# Webhook / callback (solo si Factus lo ofrece; si no, reconciliación por job).
FACTUS_WEBHOOK_ENABLED=false
FACTUS_WEBHOOK_SECRET=

# Reconciliación / almacenamiento privado de PDF/XML.
FACTUS_RECONCILIATION_ENABLED=true
FACTUS_RECONCILIATION_MINUTES=10
FACTUS_RETRY_SWEEP_MINUTES=15
FACTUS_RECONCILIATION_MAX_AGE_MINUTES=1440
FACTUS_STORAGE_DISK=local
FACTUS_STORAGE_PATH=invoices

# ── Factus V2 — defaults de documento (códigos de catálogo, ver docs/factus) ──
FACTUS_DOCUMENT_CODE=01
FACTUS_OPERATION_TYPE=10
FACTUS_DEFAULT_UNIT_MEASURE_CODE=94
FACTUS_DEFAULT_STANDARD_CODE=999
FACTUS_DEFAULT_TAX_CODE=01
FACTUS_DEFAULT_TAX_RATE=19.00
FACTUS_DEFAULT_PAYMENT_FORM=1
FACTUS_DEFAULT_PAYMENT_METHOD_CODE=10
FACTUS_DEFAULT_TRIBUTE_CODE=ZZ
FACTUS_DEFAULT_LEGAL_ORGANIZATION_CODE=2
FACTUS_DEFAULT_MUNICIPALITY_CODE=
# Notas crédito (rango y conceptos propios de la resolución de NC)
FACTUS_CREDIT_NUMBERING_RANGE_ID=
FACTUS_CREDIT_CORRECTION_CONCEPT_CODE=2
FACTUS_CREDIT_CUSTOMIZATION_ID=20

# 🔒 Bloqueo tributario de producción: poner en true SOLO cuando el contador
# confirme el tratamiento de IVA (excluido/exento/19%) de membresías y productos.
FACTUS_TAX_DECISION_CONFIRMED=false

# Emisión automática de factura por origen (apagada por defecto: factura
# opcional a solicitud del cliente). Poner en true para emitir al confirmar pago.
FACTUS_MEMBERSHIPS_AUTO_EMIT=false
FACTUS_PRODUCT_SALES_AUTO_EMIT=false

BILLING_EMAIL_LOGO_URL=https://api.ironbodyneiva.cloud/brand/iron-body-logo.png
BILLING_EMAIL_SUPPORT=facturacion@ironbodyneiva.cloud
