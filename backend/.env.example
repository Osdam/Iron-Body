# ── WorkoutX (referencias visuales de ejercicios con GIF) ───────────────────
WORKOUTX_API_KEY=
WORKOUTX_BASE_URL=https://api.workoutxapp.com

# ── Proveedor de referencias visuales (fitgif | workoutx | local) ───────────
EXERCISE_PROVIDER=fitgif
SHOW_WORKOUTX_GIFS=false
SHOW_FITGIF_GIFS=true
SHOW_FREE_EXERCISE_DB=false
# FitGif: proveedor principal (API de pago). Key en https://fitgif.vercel.app
FITGIF_BASE_URL=https://fitgif.vercel.app
FITGIF_API_KEY=
FITGIF_VIDEO_SPEED=1.5
FITGIF_VIDEO_FPS=60
FITGIF_VIDEO_WIDTH=540
FITGIF_VIDEO_CRF=26
# Free Exercise DB: fallback open data (sin key, sin watermark).
FREEEXERCISEDB_BASE_URL=https://cdn.jsdelivr.net/gh/yuhonas/free-exercise-db@main

# ── IRON IA (OpenAI) — SOLO backend, la key NUNCA va en Flutter ─────────────
# Flutter → Laravel → OpenAI. No subir la key al repositorio.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com
IRON_AI_ENABLED=true
IRON_AI_MAX_CONTEXT_MESSAGES=12
# IRON_AI_TEMPERATURE=0.4
# IRON_AI_MAX_TOKENS=600
# IRON_AI_TIMEOUT=30
