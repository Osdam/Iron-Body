APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

MEMBER_REGISTRATION_TOKEN=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL es la ÚNICA base real (dev y producción). NO usar SQLite.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ironbody
DB_USERNAME=ironbody
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── ePayco (Davivienda) — modo PRUEBAS. SOLO backend, nunca en Flutter ──────────
EPAYCO_TEST=true
EPAYCO_PUBLIC_KEY= ddd2850ce7dc9f3baff334109af830c8
EPAYCO_PRIVATE_KEY=07286dc3b84d13f2b9e47432a7b9b990
EPAYCO_P_CUST_ID_CLIENTE= 1581778
EPAYCO_P_KEY=251e325dc87b6da4442fda03dfd28dd5a4adc8e3
EPAYCO_RESPONSE_URL=
EPAYCO_CONFIRMATION_URL=

# ── WorkoutX (referencias visuales de ejercicios con GIF) ───────────────────
WORKOUTX_API_KEY=
WORKOUTX_BASE_URL=https://api.workoutxapp.com

# ── Proveedor de referencias visuales (fitgif | workoutx | local) ───────────
EXERCISE_PROVIDER=fitgif
SHOW_WORKOUTX_GIFS=false
SHOW_FITGIF_GIFS=true
SHOW_FREE_EXERCISE_DB=false
# FitGif: proveedor principal (API de pago). Key en https://fitgif.vercel.app
FITGIF_BASE_URL=https://fitgif.vercel.app
FITGIF_API_KEY=
FITGIF_VIDEO_SPEED=1.5
FITGIF_VIDEO_FPS=60
FITGIF_VIDEO_WIDTH=540
FITGIF_VIDEO_CRF=26
# Free Exercise DB: fallback open data (sin key, sin watermark).
FREEEXERCISEDB_BASE_URL=https://cdn.jsdelivr.net/gh/yuhonas/free-exercise-db@main

# ── IRON IA (OpenAI) — SOLO backend, la key NUNCA va en Flutter ─────────────
# Flutter → Laravel → OpenAI. No subir la key al repositorio.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com
# IRON IA multimodal — modelos configurables (no se queman en código).
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4.1-mini
# IRON IA — conversación de voz en vivo (OpenAI Realtime GA).
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy
IRON_AI_REALTIME_ENABLED=true
IRON_AI_ENABLED=true
IRON_AI_MAX_CONTEXT_MESSAGES=12
# IRON_AI_TEMPERATURE=0.4
# IRON_AI_MAX_TOKENS=600
# IRON_AI_TIMEOUT=30
# IRON_AI_MEDIA_TIMEOUT=60
# IRON_AI_MAX_AUDIO_SECONDS=60
# IRON_AI_MAX_IMAGE_SIZE_MB=5
# IRON_AI_MAX_AUDIO_SIZE_MB=25
